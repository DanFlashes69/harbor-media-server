# Never commit credentials
.env
*.env
.env.*
!.env.example

# OS files
Thumbs.db
.DS_Store
desktop.ini

# VPN config files (contain server IPs and auth)
gluetun/*.ovpn
gluetun/*.crt
gluetun/*.key
gluetun/*.pem

# Docker runtime data (generated at runtime, not config)
*/data/
*/logs/
logs/
reports/
backups/
_backup_*/
retro-scan/
*.zip
synology-sync-logs/
synology-parity/
tmp-orchestrator-live-patch/
synology-services-api*.json

# Tdarr runtime data
tdarr/server/
tdarr/configs/
tdarr/logs/
tdarr/transcode_cache/

# Immich data
immich/

# Pi-hole data
pihole/

# Scanner runtime
scanner/logs/

# App config directories (runtime-generated, not our templates)
radarr/config/
sonarr/config/
lidarr/config/
bazarr/config/
prowlarr/config/
plex/config/
overseerr/config/
qbittorrent/config/
portainer/data/

# Local repo backups / generated task exports
*.bak
*.tmp

# Editor files
*.swp
*.swo
*~
.vscode/
.idea/

# Python cache
__pycache__/
*.pyc
