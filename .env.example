# ============================================================================
#  HARBOR MEDIA SERVER — Environment Variables
#  Copy this file to .env and fill in your values before running docker compose
#  Command: copy .env.example .env
# ============================================================================

# --- PATHS ---
# Where Docker config data lives (e.g., D:\docker or /opt/docker)
DOCKER_ROOT=D:\docker

# Where your media and downloads live (e.g., D:\NAS or /mnt/nas)
DATA_ROOT=D:\NAS

# Browser-facing host used for generated Homepage runtime links.
# Leave as localhost if Homepage is mainly used on the server itself.
# Set this to your server hostname or LAN IP if you want the generated links
# to work from other devices on your network.
SERVER_HOST=localhost

# --- TIMEZONE ---
# Find yours: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIMEZONE=America/New_York

# --- VPN CREDENTIALS ---
# Get from your VPN provider's manual OpenVPN configuration page
# Example providers: ProtonVPN, AirVPN, etc.
VPN_USERNAME=your_vpn_username_here
VPN_PASSWORD=your_vpn_password_here

# --- QBITTORRENT ---
# Used by the port-updater service to authenticate to qBittorrent.
# Keep these in sync with the actual qBittorrent WebUI credentials you set after first login.
QBIT_USER=admin
QBIT_PASS=change_me_to_your_qbit_password

# --- PI-HOLE ---
PIHOLE_PASSWORD=your_pihole_password_here

# --- IMMICH ---
# Set a strong password for the Immich database (can be anything, just make it secure)
IMMICH_DB_PASSWORD=change_me_to_a_strong_password

# --- PLEX ---
# Use the LAN URL Plex should advertise to local clients and for remote access.
# Example: http://192.168.1.100:32400/
PLEX_ADVERTISE_IP=http://192.168.1.100:32400/

# --- CLOUDFLARE TUNNEL (optional) ---
# Use this only if you want Plex remote access through a Cloudflare Tunnel.
# Get the run token from Cloudflare Zero Trust > Networks > Tunnels > your tunnel > Add connector.
CLOUDFLARE_TUNNEL_TOKEN=your_cloudflare_tunnel_run_token_here

# --- API KEYS (fill these in AFTER first launch) ---
# You'll get these from each app's Settings > General > API Key after setup
RADARR_API_KEY=
SONARR_API_KEY=
LIDARR_API_KEY=
